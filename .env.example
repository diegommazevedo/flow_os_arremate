# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/flowos"
DIRECT_URL="postgresql://postgres:password@localhost:5432/flowos"

# ── MCP (Cursor) — lidos por scripts/mcp-run.cjs (.env e opcional .env.mcp) ─
# Chave 21st Magic: https://21st.dev/magic/console
# MAGIC_21ST_API_KEY=""
# GitHub PAT (repo, PRs): https://github.com/settings/tokens
# GITHUB_PERSONAL_ACCESS_TOKEN=""
# URL só para o MCP Postgres (se vazio, usa DATABASE_URL acima)
# MCP_POSTGRES_URL=""
# Raiz permitida ao MCP filesystem (se vazio, usa a pasta do repositório)
# MCP_FILESYSTEM_ROOT=""

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_ORG_ID="org-..."

# ── Brain IA ───────────────────────────────────────────────────────────────
BRAIN_MODEL_GATEWAY="gpt-4o-mini"
BRAIN_MODEL_PATTERN="gpt-4o"
BRAIN_MODEL_FINETUNE="ft:gpt-4o-mini:flow-os:v1"
BRAIN_MODEL_LOCAL="http://localhost:11434/v1"
BRAIN_MEMORY_TTL_DAYS="90"

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3030"
APP_SECRET="your-app-secret-min-32-chars"

# ── WhatsApp Meta API ──────────────────────────────────────────────────────
# Configurar no Meta Business Manager → WhatsApp → API Setup
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""
META_WEBHOOK_VERIFY_TOKEN=""
META_AUTO_REPLY="false"
# Evolution — dev: docker-compose evolution-api :8080. Produção (Railway flowos-web): EVOLUTION_API_URL
# deve ser a URL pública do serviço Evolution no Railway; EVOLUTION_API_KEY igual à AUTHENTICATION_API_KEY
# da Evolution; EVOLUTION_WEBHOOK_TOKEN igual ao header apikey que a Evolution envia ao FlowOS.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=mude-esta-chave-em-producao
# Header apikey esperado em POST /api/webhooks/evolution (definir igual na Evolution WEBHOOK).
EVOLUTION_WEBHOOK_TOKEN=flowos-evolution-2026
# Nome da instância na Evolution (tem de bater com WorkspaceIntegration.config.EVOLUTION_INSTANCE_NAME).
EVOLUTION_INSTANCE_NAME=arrematador_01

# Workspace padrão para mensagens de entrada sem sessão
WEBHOOK_DEFAULT_WORKSPACE_ID=""

# ── Rocket.Chat Bot ─────────────────────────────────────────────────────────
ROCKET_WEBHOOK_SECRET=""
ROCKET_API_URL="https://chat.seudominio.com"
ROCKET_BOT_USER_ID=""
ROCKET_BOT_TOKEN=""
NEXT_PUBLIC_ROCKET_URL="https://chat.seudominio.com"

# ── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="flowos"
MINIO_REGION="us-east-1"

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD="flowos-redis-2026"
REDIS_URL="redis://localhost:6379"

# ── Portal JWT ──────────────────────────────────────────────────────────────
PORTAL_JWT_SECRET="your-portal-jwt-secret-min-32-chars"
PORTAL_SESSION_SECRET="your-portal-session-secret-min-32-chars"

# ── Dev helpers ─────────────────────────────────────────────────────────────
DEFAULT_WORKSPACE_ID=""

# ── Sector Template ────────────────────────────────────────────────────────
# real-estate | clinic | law-firm | construction | hospitality
FLOW_OS_TEMPLATE="real-estate"
FLOW_OS_WORKSPACE_SLUG="meu-negocio"
