// FlowOS v4 — Schema Universal
// Deal.meta: Json absorve qualquer especificidade de setor sem colunas novas.
// Trocar de setor = novo ZodSchema, zero migrations.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 1 — WORKSPACE (tenant)
// ─────────────────────────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  sector      String   // "real-estate" | "clinic" | "law-firm" | "construction" | "hospitality"
  settings    Json     @default("{}")   // configurações do setor (nunca schema do core)
  logoUrl     String?
  planTier    String   @default("free") // free | starter | pro | enterprise
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          Member[]
  stages           Stage[]
  deals            Deal[]
  contacts         Contact[]
  tasks            Task[]
  flows            Flow[]
  agents           Agent[]
  memories         BrainMemory[]
  knowledgeChunks  KnowledgeChunk[]
  auditLogs        AgentAuditLog[]
  usageMetrics     BrainUsageMetric[]
  rpaLogs          RpaLog[]
  documents        Document[]
  notes            DealNote[]
  savedFilters     SavedFilter[]
  chatSessions     ChatSession[]
  chatNotes        ChatNote[]
  chatTags         ChatTag[]
  departments      Department[]
  respostasRapidas RespostaRapida[]
  integrations     WorkspaceIntegration[]
  agentConfigs     AgentConfig[]
  protocols        Protocol[]
  protocolMessages ProtocolMessage[]
  internalChannels InternalChannel[]
  internalMessages InternalMessage[]
  emailAccounts    EmailAccount[]
  emails           Email[]
  partners            Partner[]
  fieldAgentProfiles  FieldAgentProfile[]
  fieldAssignments    FieldAssignment[]
  fieldEvidences      FieldEvidence[]
  propertyDossiers    PropertyDossier[]
  dossierDocuments    DossierDocument[]
  tags                Tag[]
  contactTags         ContactTag[]
  campaigns           Campaign[]
  campaignItems       CampaignItem[]
  dealParallels       DealParallel[]
  fieldWorkflows      FieldWorkflow[]
  missionProfiles     MissionProfile[]
  paymentOrders       PaymentOrder[]
  dossierChecklists   DossierChecklist[]
  editais             Edital[]

  @@map("workspaces")
}

model Member {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String     // Supabase Auth UUID
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
  /// Acesso global: gestão de workspaces (painel admin).
  SUPER_ADMIN
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 3 — KANBAN (Stage + Deal)
// ─────────────────────────────────────────────────────────────────────────────

model Stage {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#6366f1")
  position    Int
  wipLimit    Int?     // Work-In-Progress limit (null = sem limite)
  slaDays     Int?     // SLA máximo em dias (null = sem SLA)
  isWon       Boolean  @default(false)
  isLost      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deals       Deal[]

  @@unique([workspaceId, position])
  @@map("stages")
}

model Deal {
  id          String    @id @default(cuid())
  workspaceId String
  stageId     String
  title       String
  value       Decimal?  @db.Decimal(15, 2)
  probability Int?      @default(50) // 0-100%
  ownerId     String?   // userId do responsável
  contactId   String?
  closedAt    DateTime?
  expectedCloseDate DateTime?
  lostReason  String?
  // ── O campo universal — toda especificidade de setor vive aqui ──
  meta        Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stage       Stage     @relation(fields: [stageId], references: [id])
  contact     Contact?  @relation(fields: [contactId], references: [id])
  tasks       Task[]
  flowEvents  FlowEvent[]
  documents   Document[]
  notes       DealNote[]
  protocols   Protocol[]
  internalChannels InternalChannel[]
  internalMessages InternalMessage[]
  protocolSeq Int       @default(0)
  fieldAssignments FieldAssignment[]
  propertyDossier  PropertyDossier?
  campaignItems    CampaignItem[]
  dealParallels    DealParallel[]
  edital           Edital?

  @@index([workspaceId, stageId])
  @@index([workspaceId, ownerId])
  @@map("deals")
}

/// Processos paralelos condicionais (não são stages lineares do funil).
model DealParallel {
  id          String          @id @default(cuid())
  workspaceId String
  dealId      String
  type        ParallelType
  status      ParallelStatus  @default(INACTIVE)
  activatedAt DateTime?
  completedAt DateTime?
  meta        Json            @default("{}")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, type])
  @@index([workspaceId])
  @@map("deal_parallels")
}

enum ParallelType {
  CONDOMINIO
  AVERBACAO
  DESOCUPACAO
}

enum ParallelStatus {
  INACTIVE
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

// ─────────────────────────────────────────────────────────────────────────────
// DOCUMENT (artefatos gerados: PDF, planilhas, certidões)
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id          String    @id @default(cuid())
  workspaceId String
  dealId      String?
  name        String
  url         String    @db.Text   // presigned URL ou URL permanente
  contentType String    @default("application/pdf")
  collection  String    // "deal_docs" | "contracts" | "certificates"
  sizeBytes   Int?
  expiresAt   DateTime? // TTL do presigned URL (null = permanente)
  meta        Json      @default("{}")
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal        Deal?     @relation(fields: [dealId], references: [id])

  @@index([workspaceId])
  @@index([dealId])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTATO
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  phone       String?
  document    String?  // CPF/CNPJ (armazenado encriptado — SEC-11)
  type        ContactType @default(PERSON)
  /// Ciclo comercial do lead no cockpit (PROSPECT → LEAD → ACTIVE).
  leadLifecycle LeadLifecycle @default(PROSPECT)
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deals       Deal[]
  contactTags ContactTag[]
  campaignItems CampaignItem[]

  @@index([workspaceId])
  @@index([workspaceId, phone])  // resolveOrCreateContact dedup
  @@map("contacts")
}

enum ContactType {
  PERSON
  COMPANY
}

enum LeadLifecycle {
  PROSPECT
  LEAD
  ACTIVE
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 2 — EISENHOWER (Task)
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id          String          @id @default(cuid())
  workspaceId String
  dealId      String?
  title       String
  description String?
  type        String?
  assigneeId  String?         // userId
  aparelhoOrigem String?
  /// Canal omnichannel (espelha JSON em description quando preenchido).
  channel     String?
  /// WhatsApp grupo Evolution: id estável para uma task por grupo.
  groupId     String?
  quadrant    EisenhowerQuadrant @default(Q4_ELIMINATE)
  priority    TaskPriority    @default(MEDIUM)
  urgent      Boolean         @default(false)
  important   Boolean         @default(false)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal        Deal?     @relation(fields: [dealId], references: [id])
  chatSession ChatSession?
  protocols   Protocol[]

  @@index([workspaceId, assigneeId])
  @@index([workspaceId, quadrant])
  @@index([workspaceId, channel])
  @@index([workspaceId, groupId])
  @@index([workspaceId, completedAt])  // getConversations: tasks abertas
  @@index([workspaceId, dealId, channel, completedAt]) // upsertTask dedup
  @@map("tasks")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum EisenhowerQuadrant {
  Q1_DO      // Urgente + Importante
  Q2_PLAN    // Não urgente + Importante
  Q3_DELEGATE // Urgente + Não importante
  Q4_ELIMINATE // Não urgente + Não importante
}

enum ChatStatus {
  ABERTO
  EM_ATENDIMENTO
  AGUARDANDO
  RESOLVIDO
  FECHADO
  INDEFINIDO
}

enum ProtocolChannel {
  WHATSAPP
  PWA
  INTERNO
}

enum MessageDirection {
  IN
  OUT
  NOTE
}

enum InternalChannelType {
  CANAL
  DIRETO
  DEAL_THREAD
}

enum InternalMessageType {
  TEXTO
  ALERTA_Q1
  DEAL_REF
  PROTOCOL_REF
  SISTEMA
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 4 — MOTOR DE FLUXOS
// ─────────────────────────────────────────────────────────────────────────────

model DealNote {
  id          String   @id @default(cuid())
  workspaceId String
  dealId      String
  authorId    String
  authorName  String
  content     String   @db.Text
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([workspaceId, dealId])
  @@map("deal_notes")
}

model ChatSession {
  id                String     @id @default(cuid())
  workspaceId       String
  taskId            String     @unique
  status            ChatStatus @default(ABERTO)
  responsavelId     String?
  departamentoId    String?
  aparelhoOrigem    String?
  chatbotAtivo      Boolean    @default(true)
  arquivado         Boolean    @default(false)
  favorito          Boolean    @default(false)
  unreadCount       Int        @default(0)
  totalAtendimentos Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  workspace         Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task              Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  notas             ChatNote[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, departamentoId])
  @@index([workspaceId, arquivado])
  @@index([workspaceId, favorito])
  @@map("chat_sessions")
}

model ChatNote {
  id           String      @id @default(cuid())
  workspaceId  String
  taskId       String
  conteudo     String      @db.Text
  autorId      String
  pinned       Boolean     @default(false)
  visivelNoBot Boolean     @default(false)
  createdAt    DateTime    @default(now())

  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  session      ChatSession @relation(fields: [taskId], references: [taskId], onDelete: Cascade)

  @@index([workspaceId, taskId])
  @@map("chat_notes")
}

model ChatTag {
  id          String   @id @default(cuid())
  workspaceId String
  descricao   String
  corFundo    String   @default("#6366f1")
  corTexto    String   @default("#ffffff")
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, descricao])
  @@index([workspaceId])
  @@map("chat_tags")
}

model Department {
  id          String   @id @default(cuid())
  workspaceId String
  nome        String
  membros     String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, nome])
  @@index([workspaceId])
  @@map("departments")
}

model RespostaRapida {
  id          String   @id @default(cuid())
  workspaceId String
  atalho      String
  texto       String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, atalho])
  @@index([workspaceId])
  @@map("respostas_rapidas")
}

model Protocol {
  id            String          @id @default(cuid())
  workspaceId   String
  number        String          @unique
  dealId        String
  taskId        String?
  status        ChatStatus      @default(ABERTO)
  canal         ProtocolChannel @default(WHATSAPP)
  assunto       String?
  resolvidoEm   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal          Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  task          Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  mensagens     ProtocolMessage[]
  internalLinks InternalMessage[]

  @@index([workspaceId, dealId])
  @@index([workspaceId, status])
  @@index([workspaceId, number])
  @@map("protocols")
}

model ProtocolMessage {
  id          String           @id @default(cuid())
  workspaceId String
  protocolId  String
  direction   MessageDirection
  canal       ProtocolChannel
  conteudo    String           @db.Text
  autorId     String?
  templateId  String?
  lido        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  protocol    Protocol         @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  @@index([workspaceId, protocolId])
  @@index([workspaceId, createdAt])
  @@map("protocol_messages")
}

model InternalChannel {
  id          String              @id @default(cuid())
  workspaceId String
  nome        String
  tipo        InternalChannelType @default(CANAL)
  dealId      String?
  membros     String[]
  createdAt   DateTime            @default(now())

  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal        Deal?               @relation(fields: [dealId], references: [id], onDelete: SetNull)
  mensagens   InternalMessage[]

  @@unique([workspaceId, nome])
  @@index([workspaceId, tipo])
  @@map("internal_channels")
}

model InternalMessage {
  id          String              @id @default(cuid())
  workspaceId String
  channelId   String
  autorId     String
  conteudo    String              @db.Text
  tipo        InternalMessageType @default(TEXTO)
  dealId      String?
  protocolId  String?
  editado     Boolean             @default(false)
  createdAt   DateTime            @default(now())

  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel     InternalChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  deal        Deal?               @relation(fields: [dealId], references: [id], onDelete: SetNull)
  protocol    Protocol?           @relation(fields: [protocolId], references: [id], onDelete: SetNull)

  @@index([workspaceId, channelId])
  @@index([workspaceId, createdAt])
  @@map("internal_messages")
}

model SavedFilter {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  field       String
  operator    String
  value       String?
  createdBy   String
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("saved_filters")
}

model Flow {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  description String?
  trigger     Json        // { type: 'event'|'cron'|'webhook'|'manual', config: {...} }
  isActive    Boolean     @default(true)
  version     Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps       FlowStep[]
  events      FlowEvent[]

  @@index([workspaceId, isActive])
  @@map("flows")
}

model FlowStep {
  id          String   @id @default(cuid())
  flowId      String
  position    Int
  type        FlowStepType
  condition   Json?    // guarda booleano opcional
  action      Json     // { type: 'email'|'task'|'agent'|'webhook'|'stage_change', config: {...} }
  createdAt   DateTime @default(now())

  flow        Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([flowId, position])
  @@map("flow_steps")
}

enum FlowStepType {
  CONDITION
  ACTION
  AGENT_CALL
  WAIT
  BRANCH
}

model FlowEvent {
  id          String          @id @default(cuid())
  workspaceId String
  flowId      String
  dealId      String?
  status      FlowEventStatus @default(PENDING)
  triggeredAt DateTime        @default(now())
  completedAt DateTime?
  error       String?
  payload     Json            @default("{}")

  flow        Flow    @relation(fields: [flowId], references: [id])
  deal        Deal?   @relation(fields: [dealId], references: [id])

  @@index([workspaceId, flowId])
  @@map("flow_events")
}

enum FlowEventStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 5 — AGENTRUNTIME
// ─────────────────────────────────────────────────────────────────────────────

model Agent {
  id                 String   @id @default(cuid())
  workspaceId        String
  name               String
  persona            String   @default("Assistente profissional e objetivo.")
  skills             String[] // lista de tool-ids permitidos
  monthlyBudgetUsd   Decimal  @default(50) @db.Decimal(8, 2)
  usedBudgetThisMonth Decimal @default(0)  @db.Decimal(8, 2)
  isActive           Boolean  @default(true)
  meta               Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memories    BrainMemory[]
  auditLogs   AgentAuditLog[]

  @@index([workspaceId])
  @@map("agents")
}

model AgentAuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String
  action      String   // ex: "deal.create", "task.assign", "flow.trigger"
  input       Json
  output      Json
  modelUsed   String
  tokensUsed  Int
  costUsd     Decimal  @db.Decimal(8, 6)
  durationMs  Int
  success     Boolean
  error       String?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent       Agent     @relation(fields: [agentId], references: [id])

  // Append-only: sem updates, sem deletes (garantido por RLS no Supabase)
  @@index([workspaceId, agentId])
  @@index([createdAt])
  @@map("agent_audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 6 — BRAIN IA (memória + métricas)
// ─────────────────────────────────────────────────────────────────────────────

model BrainMemory {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String
  content     String   // fragmento de conhecimento
  /// pgvector — busca semântica por similaridade cosine
  /// Gerado via text-embedding-3-small (1536 dims)
  embedding   Unsupported("vector(1536)")?
  source      String   // "interaction" | "pattern" | "manual"
  relevance   Float    @default(1.0)
  expiresAt   DateTime // TTL: 90 dias por padrão
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent       Agent     @relation(fields: [agentId], references: [id])

  @@index([workspaceId, agentId])
  @@map("brain_memories")
}

// ─── Knowledge Chunks (RAG) ───────────────────────────────────────────────────
// Fragmentos de documentos/bases de conhecimento com embedding para RAG.
// Separado do BrainMemory: Memória = histórico de interações;
//                          KnowledgeChunk = documentos indexados pelo workspace.

model KnowledgeChunk {
  id          String   @id @default(cuid())
  workspaceId String
  /// Origem do chunk: "document" | "manual" | "web" | "integration"
  source      String
  /// Título ou referência do documento original
  title       String
  /// Conteúdo textual do chunk (max ~8k chars para caber no contexto)
  content     String   @db.Text
  /// Hash SHA-256 do conteúdo para deduplicação
  contentHash String
  /// Embedding OpenAI text-embedding-3-small — 1536 dims
  embedding   Unsupported("vector(1536)")?
  /// Metadados arbitrários (página, seção, tags, etc.)
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, contentHash])
  @@index([workspaceId])
  @@map("knowledge_chunks")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 7 — RPA LOG
// ─────────────────────────────────────────────────────────────────────────────

model RpaLog {
  id           String    @id @default(cuid())
  workspaceId  String
  agentId      String?   // qual agente/worker disparou
  status       RpaStatus
  rowsFound    Int       @default(0)
  rowsNew      Int       @default(0)
  rowsSkipped  Int       @default(0)
  rowsFailed   Int       @default(0)
  duration     Int       // duração em ms
  domHash      String?   // SHA-256 do DOM scrapeado
  dryRun       Boolean   @default(false)
  errorMessage String?
  createdAt    DateTime  @default(now())

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@map("rpa_logs")
}

enum RpaStatus {
  SUCCESS
  FAILED
  LAYOUT_CHANGED
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 9 — EMAIL INTEGRADO
// ─────────────────────────────────────────────────────────────────────────────

model EmailAccount {
  id          String    @id @default(cuid())
  workspaceId String
  tipo        String
  nome        String
  email       String
  config      Json
  status      String    @default("ACTIVE")
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  emails      Email[]

  @@unique([workspaceId, email])
  @@index([workspaceId, status])
  @@map("email_accounts")
}

model Email {
  id          String   @id @default(cuid())
  workspaceId String
  accountId   String
  messageId   String   @unique
  threadId    String?
  from        String
  fromName    String?
  to          String[]
  cc          String[]
  subject     String
  bodyText    String?
  bodyHtml    String?
  attachments Json?
  dealId      String?
  contactId   String?
  protocolId  String?
  eisenhower  String?
  lido        Boolean  @default(false)
  respondido  Boolean  @default(false)
  importante  Boolean  @default(false)
  rascunho    Boolean  @default(false)
  enviado     Boolean  @default(false)
  labels      String[]
  receivedAt  DateTime
  createdAt   DateTime @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account     EmailAccount @relation(fields: [accountId], references: [id])

  @@index([workspaceId, dealId])
  @@index([workspaceId, lido])
  @@index([workspaceId, receivedAt])
  @@index([workspaceId, eisenhower])
  @@map("emails")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 8 — INTEGRAÇÕES + CONFIGURAÇÕES DE AGENTES
// ─────────────────────────────────────────────────────────────────────────────

model WorkspaceIntegration {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // WHATSAPP_META | WHATSAPP_EVOLUTION | MINIO | EMAIL | PORTAL_JWT
  name        String
  config      Json     @default("{}") // credenciais criptografadas em repouso
  status      String   @default("ACTIVE") // ACTIVE | INACTIVE | ERROR
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type, status])  // resolveIntegration lookup
  @@map("workspace_integrations")
}

model AgentConfig {
  id          String   @id @default(cuid())
  workspaceId String
  agentName   String   // ex: PAYMENT_RECOVERY | RPA_EXTERNAL | REPORT_GEN | TOKEN_ROUTER
  config      Json     @default("{}")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, agentName])
  @@map("agent_configs")
}

model BrainUsageMetric {
  id              String   @id @default(cuid())
  workspaceId     String
  month           String   // "2026-03"
  model           String
  tokensUsed      Int      @default(0)
  costUsd         Decimal  @default(0) @db.Decimal(10, 4)
  requestCount    Int      @default(0)
  cacheHitCount   Int      @default(0)
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, month, model])
  @@map("brain_usage_metrics")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 10 — PARCEIROS + PIPELINE MOTOBOY/FIELD AGENT
// ─────────────────────────────────────────────────────────────────────────────

model Partner {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  phone       String?
  email       String?
  document    String?     // CPF/CNPJ
  type        PartnerType
  isActive    Boolean     @default(true)
  meta        Json        @default("{}")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fieldAgentProfile FieldAgentProfile?

  @@unique([workspaceId, phone])
  @@index([workspaceId])
  @@index([workspaceId, type])
  @@map("partners")
}

enum PartnerType {
  LEILOEIRO
  CORRETOR
  DESPACHANTE
  FIELD_AGENT
  EXTERNO
}

enum ProfileLevel {
  DOWN
  STANDARD
  UP
}

/// Perfil de missão de campo — valores, itens (P-02 em JSON) e regras de skip.
model MissionProfile {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  description String?
  isDefault   Boolean      @default(false)
  isActive    Boolean      @default(true)
  level       ProfileLevel @default(STANDARD)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  bandeiradaValue Int    @default(4000)
  maxValue        Int    @default(8000)
  currency        String @default("BRL")

  /// MissionItemConfig[] — P-02
  items Json @default("[]")

  skipPenalty      Boolean  @default(true)
  skipRequiresText Boolean  @default(true)
  skipMinChars     Int      @default(10)
  skipMaxItems     Int      @default(3)
  skipReasons      String[] @default([])

  agentLimit      Int @default(3)
  followupDelayMs Int @default(7200000)
  deadlineHours   Int @default(48)

  /// { ufs?: string[]; cities?: string[]; keywords?: string[]; priority?: number }
  autoSelectRules Json @default("{}")

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignments  FieldAssignment[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("mission_profiles")
}

model FieldAgentProfile {
  id            String            @id @default(cuid())
  workspaceId   String
  partnerId     String            @unique
  cities        String[]
  states        String[]
  pricePerVisit Decimal           @db.Decimal(10, 2)
  currency      String            @default("BRL")
  avgRating     Decimal?          @db.Decimal(3, 2)
  totalJobs     Int               @default(0)
  availability  AgentAvailability @default(AVAILABLE)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  cpf        String?
  pixKey     String?
  pixKeyType PixKeyType?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  partner     Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  assignments FieldAssignment[]

  @@index([workspaceId])
  @@index([states])
  @@map("field_agent_profiles")
}

enum AgentAvailability {
  AVAILABLE
  BUSY
  INACTIVE
}

model FieldAssignment {
  id            String           @id @default(cuid())
  workspaceId   String
  dealId        String
  agentId       String
  profileId     String?
  status        AssignmentStatus @default(PENDING_CONTACT)
  contactedAt   DateTime?
  acceptedAt    DateTime?
  completedAt   DateTime?
  rejectedAt    DateTime?
  rejectionNote String?
  priceAgreed   Decimal?         @db.Decimal(10, 2)
  waMessageId   String?
  evidenceCount Int              @default(0)
  /// Token opaco para PWA público (GET /api/vistoria/[token]) — SEC-08 sem expor id interno.
  pwaAccessToken String          @unique @default(cuid())
  /// PWA: tentativas de confirmação, itemStates, descricaoTexto, pixPendente, etc.
  meta          Json             @default("{}")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal       Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  agent      FieldAgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
  profile      MissionProfile?   @relation(fields: [profileId], references: [id], onDelete: SetNull)
  evidences    FieldEvidence[]
  paymentOrder PaymentOrder?

  @@index([workspaceId])
  @@index([dealId])
  @@index([agentId])
  @@index([profileId])
  @@map("field_assignments")
}

enum AssignmentStatus {
  PENDING_CONTACT
  CONTACTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
  NO_RESPONSE
  CANCELLED
}

model FieldEvidence {
  id           String       @id @default(cuid())
  workspaceId  String
  assignmentId String
  dealId       String
  type         EvidenceType
  mediaUrl     String
  mediaKey     String
  mimeType     String
  description  String?
  aiAnalysis   Json?
  capturedAt   DateTime     @default(now())
  createdAt    DateTime     @default(now())

  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignment FieldAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, dealId])
  @@index([assignmentId])
  @@map("field_evidences")
}

enum EvidenceType {
  PHOTO_EXTERIOR
  PHOTO_SURROUNDINGS
  PHOTO_ACCESS
  VIDEO_EXTERIOR
  VIDEO_SURROUNDINGS
  AUDIO_DESCRIPTION
  DOCUMENT_PHOTO
}

model PropertyDossier {
  id             String        @id @default(cuid())
  workspaceId    String
  dealId         String        @unique
  clientId       String?
  status         DossierStatus @default(DRAFT)
  fieldScore     Decimal?      @db.Decimal(4, 2)
  riskScore      Decimal?      @db.Decimal(4, 2)
  aiSummary      String?
  reportUrl      String?
  reportKey      String?
  generatedAt    DateTime?
  sharedWithLead Boolean       @default(false)
  sharedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal      Deal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  documents DossierDocument[]
  checklist DossierChecklist?

  @@index([workspaceId])
  @@map("property_dossiers")
}

enum DossierStatus {
  DRAFT
  FIELD_PENDING
  FIELD_COMPLETE
  DOCS_PENDING
  READY
  GENERATED
  SHARED
}

model DossierDocument {
  id          String       @id @default(cuid())
  workspaceId String
  dossierId   String
  type        DocumentType
  name        String
  mediaUrl    String
  mediaKey    String
  mimeType    String
  issuedAt    DateTime?
  expiresAt   DateTime?
  uploadedAt  DateTime     @default(now())

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dossier   PropertyDossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([workspaceId, dossierId])
  @@map("dossier_documents")
}

enum DocumentType {
  MATRICULA
  CERTIDAO_ONUS
  CERTIDAO_ACOES
  CERTIDAO_DEBITOS
  EXTRATO_FGTS
  DEBITOS_MUNICIPAIS
  ITBI
  OUTRO
}

// ─────────────────────────────────────────────────────────────────────────────
// COCKPIT — etiquetas, campanhas em massa (leads / motoboy / dossiê)
// ─────────────────────────────────────────────────────────────────────────────

model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#888888")
  createdAt   DateTime @default(now())

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  ContactTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tags")
}

model ContactTag {
  id          String   @id @default(cuid())
  workspaceId String
  contactId   String
  tagId       String
  addedAt     DateTime @default(now())
  addedBy     String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([workspaceId])
  @@map("contact_tags")
}

model Campaign {
  id           String         @id @default(cuid())
  workspaceId  String
  name         String
  type         CampaignType   @default(DOSSIER)
  status       CampaignStatus @default(DRAFT)
  totalLeads   Int            @default(0)
  sentCount    Int            @default(0)
  doneCount    Int            @default(0)
  ratePerHour  Int            @default(20)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  /// Payload extra: waMessage, filtros usados na criação, etc.
  meta         Json           @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items     CampaignItem[]

  @@index([workspaceId])
  @@map("campaigns")
}

enum CampaignType {
  DOSSIER
  WA_MESSAGE
  WA_TEMPLATE
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

model CampaignItem {
  id          String             @id @default(cuid())
  workspaceId String
  campaignId  String
  contactId   String
  dealId      String?
  status      CampaignItemStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal      Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@unique([campaignId, contactId])
  @@index([workspaceId, campaignId])
  @@map("campaign_items")
}

enum CampaignItemStatus {
  PENDING
  RUNNING
  DONE
  ERROR
  SKIPPED
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 10 — PAGAMENTO, CHECKLIST, EDITAL
// ─────────────────────────────────────────────────────────────────────────────

enum PixKeyType {
  CPF
  EMAIL
  PHONE
  EVP
}

enum PaymentStatus {
  PENDING
  APPROVED
  PAID
  FAILED
  CANCELLED
}

model PaymentOrder {
  id           String        @id @default(cuid())
  workspaceId  String
  assignmentId String        @unique
  agentId      String
  amount       Int
  pixKey       String
  pixKeyType   PixKeyType
  status       PaymentStatus @default(PENDING)
  breakdown    Json
  approvedBy   String?
  approvedAt   DateTime?
  paidAt       DateTime?
  paidRef      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignment FieldAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
  @@map("payment_orders")
}

model DossierChecklist {
  id          String    @id @default(cuid())
  workspaceId String
  dossierId   String    @unique
  items       Json
  gateB       Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dossier   PropertyDossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("dossier_checklists")
}

enum EditalSource {
  UPLOAD
  RPA_CAIXA
  RPA_LEILOEIRO
  RPA_DOU
  RPA_TJ
}

enum EditalStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum UrgencyLevel {
  CRITICAL
  HIGH
  NORMAL
  EXPIRED
  POS_48H
}

enum DeliveryContext {
  PRE_ARREMATE
  POS_ARREMATE
}

model Edital {
  id               String          @id @default(cuid())
  workspaceId      String
  dealId           String          @unique
  sourceType       EditalSource
  sourceUrl        String?
  fileUrl          String?
  rawText          String?         @db.Text
  status           EditalStatus    @default(PENDING)
  leilaoDate       DateTime?
  leilaoModalidade String?
  leiloeiro        String?
  varaJudicial     String?
  valorAvaliacao   Int?
  lanceMinimo      Int?
  debitosEdital    Json?
  restricoes       Json?
  prazoBoletoPago  DateTime?
  urgencyLevel     UrgencyLevel    @default(NORMAL)
  horasAteEvento   Int?
  deliveryContext  DeliveryContext @default(PRE_ARREMATE)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([leilaoDate])
  @@map("editais")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMADA 11 — FIELD WORKFLOW EDITOR
// ─────────────────────────────────────────────────────────────────────────────

enum FieldStepType {
  SEND_MESSAGE
  WAIT_RESPONSE
  WAIT_DELAY
  CONDITION
  UPDATE_STATUS
  SCHEDULE_FOLLOWUP
  DISPATCH_NEXT
}

model FieldWorkflow {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps     FieldWorkflowStep[]
  edges     FieldWorkflowEdge[]
  config    FieldWorkflowConfig?

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("field_workflows")
}

model FieldWorkflowStep {
  id         String        @id @default(cuid())
  workflowId String
  key        String
  label      String
  type       FieldStepType
  position   Int
  positionX  Float         @default(0)
  positionY  Float         @default(0)
  config     Json          @default("{}")
  createdAt  DateTime      @default(now())

  workflow  FieldWorkflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  template  FieldMessageTemplate?
  edgesFrom FieldWorkflowEdge[]  @relation("edgeSource")
  edgesTo   FieldWorkflowEdge[]  @relation("edgeTarget")

  @@unique([workflowId, key])
  @@unique([workflowId, position])
  @@map("field_workflow_steps")
}

model FieldWorkflowEdge {
  id         String  @id @default(cuid())
  workflowId String
  sourceId   String
  targetId   String
  label      String?
  condition  Json?

  workflow FieldWorkflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  source   FieldWorkflowStep @relation("edgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target   FieldWorkflowStep @relation("edgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([workflowId, sourceId, targetId])
  @@map("field_workflow_edges")
}

model FieldMessageTemplate {
  id        String   @id @default(cuid())
  stepId    String   @unique
  name      String
  body      String   @db.Text
  variables String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  step FieldWorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("field_message_templates")
}

model FieldWorkflowConfig {
  id              String  @id @default(cuid())
  workflowId      String  @unique
  agentLimit      Int     @default(3)
  followupDelayMs Int     @default(7200000)
  deadlineHours   Int     @default(48)
  priceDefault    Decimal @default(80) @db.Decimal(10, 2)
  currency        String  @default("BRL")
  evidenceTypes   Json    @default("[\"PHOTO_EXTERIOR\",\"PHOTO_SURROUNDINGS\",\"PHOTO_ACCESS\",\"VIDEO_EXTERIOR\",\"AUDIO_DESCRIPTION\"]")
  evidenceMinimum Int     @default(6)
  autoRetry       Boolean @default(true)

  workflow FieldWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("field_workflow_configs")
}
