# Evolution API no Railway — copiar variáveis para o serviço Docker (imagem atendai/evolution-api:v2.2.3).
#
# Criar serviço: Railway → teu projeto → New → Empty Service → Settings → Deploy
# → Source = Docker Image → Image = atendai/evolution-api:v2.2.3 → gerar domínio público.
#
# Depois: copiar cada linha (sem #) para Variables desse serviço. Ajustar URLs e passwords.

# URL pública HTTPS deste serviço Evolution (obrigatório; não use localhost).
# Ex.: https://evolution-production.up.railway.app
SERVER_URL=

AUTHENTICATION_TYPE=apikey
# Mesmo valor que EVOLUTION_API_KEY no serviço flowos-web.
AUTHENTICATION_API_KEY=
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

QRCODE_LIMIT=30
DEL_INSTANCE=false

DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
# OBRIGATÓRIO — se vazio, a imagem usa o .env interno (host "postgres:5432") e falha no Railway (P1001).
# No serviço evolution-api: Variables → DATABASE_CONNECTION_URI = referência à URL do plugin Postgres
# do MESMO projeto, ou cola a URI completa (hostname real tipo *.railway.internal ou proxy rlwy.net, NUNCA "postgres").
# Mesmo Postgres do flowos-web: podes usar ?schema=evolution_public para isolar tabelas da Evolution.
# postgresql://USER:PASSWORD@HOST:PORT/railway?schema=evolution_public
DATABASE_CONNECTION_URI=
DATABASE_CONNECTION_CLIENT_NAME=flow_os

# Se Redis não existir ou URI errada: logs [Redis] redis disconnected em loop.
# Opção rápida (demo): CACHE_REDIS_ENABLED=false + CACHE_LOCAL_ENABLED=true
CACHE_REDIS_ENABLED=true
# NÃO coloques só o domínio (ex.: flowos-redis-xxx.up.railway.app) — dá ERR_INVALID_URL.
# Usa a string COMPLETA do plugin Redis (Variables → REDIS_URL / REDIS_PRIVATE_URL), ou:
#   redis://:PASSWORD@HOST:6379/6
CACHE_REDIS_URI=
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

LOG_LEVEL=ERROR,WARN,INFO,LOG,DEBUG,VERBOSE,WEBHOOKS
LOG_COLOR=true
LOG_BAILEYS=debug
CONFIG_SESSION_PHONE_VERSION=

WEBHOOK_GLOBAL_ENABLED=true
# URL pública do Next (flowos-web) + path do webhook.
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
