# Variáveis a definir no serviço Next.js (flowos-web) no Railway — só Evolution.
# A API key deve ser a mesma AUTHENTICATION_API_KEY do serviço Evolution.
# O webhook token deve ser o valor que a Evolution envia no header "apikey".

# Produção típica (Railway — ajustar se o domínio mudar):
# EVOLUTION_API_URL=https://evolution-api-production-d423.up.railway.app
EVOLUTION_API_URL=
# Deve coincidir com AUTHENTICATION_API_KEY do serviço Evolution no Railway.
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_TOKEN=
# Opcional se já estiver em WorkspaceIntegration; alinhar ao nome real da instância.
EVOLUTION_INSTANCE_NAME=arrematador_01
